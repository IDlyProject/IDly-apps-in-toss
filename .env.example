PORT=3001
HOST=127.0.0.1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
VITE_IDLY_API_BASE_URL=https://idly-apps-in-toss.onrender.com
VITE_TOSS_BANNER_AD_GROUP_ID=

# PostgreSQL (Supabase → Settings → Database → Connection string)
DATABASE_URL=

# Keep false in local development unless you intentionally want to call Upstage.
# Even when true, the server calls Upstage only after consentToExternalAI=true.
UPSTAGE_ENABLE_LIVE_CALLS=false
UPSTAGE_API_KEY=

# Override only if Upstage changes endpoints or you use a proxy.
UPSTAGE_DOCUMENT_PARSE_URL=https://api.upstage.ai/v1/document-digitization
UPSTAGE_SOLAR_CHAT_URL=https://api.upstage.ai/v1/chat/completions
UPSTAGE_SOLAR_MODEL=solar-pro3
